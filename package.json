    "@sister.software/tsconfig": "^8.0.1",
    "@types/node": "^25.9.2",
    "eslint": "^9.39.4",
    "eslint-plugin-html": "^8.1.4",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "prettier-plugin-jsdoc": "^1.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.2",
